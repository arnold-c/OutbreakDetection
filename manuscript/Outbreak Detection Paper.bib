@article{yemshanovAcceptanceSamplingCosteffective2020,
  title = {Acceptance Sampling for Cost-Effective Surveillance of Emerald Ash Borer in Urban Environments},
  author = {Yemshanov, Denys and Haight, Robert G and Liu, Ning and Chen, Cuicui and MacQuarrie, Chris J K and Ryall, Krista and Venette, Robert and Koch, Frank H},
  date = {2020-03-12},
  journaltitle = {Forestry: An International Journal of Forest Research},
  shortjournal = {Forestry: An International Journal of Forest Research},
  volume = {93},
  number = {2},
  pages = {280--296},
  issn = {0015-752X},
  doi = {10.1093/forestry/cpz028},
  url = {https://doi.org/10.1093/forestry/cpz028},
  urldate = {2021-12-01},
  abstract = {We develop an acceptance sampling approach for surveillance of the emerald ash borer (EAB), a harmful forest pest, in Winnipeg, Canada. We compare sampling strategies computed with two different management objectives. The first objective maximizes the expected area with detected infestations and the second objective minimizes the expected number of undetected infested trees in sites that were not inspected or where inspection did not find an infestation. The choice of the management objective influences the survey strategy: achieving the first objective involves selecting sites with high infestation rates proximal to the infested area, whereas the second objective requires inspecting sites with both high infestation rates and high host densities. Adding uncertainty prescribes inspecting a larger area with lower sampling rates and extending the surveys to farther distances from the infested locations. If a decision maker wants to minimize the worst-case damage from failed detections, the optimal strategy is to survey more sites with high host densities at farther distances, where EAB arrivals could cause significant damage if not detected quickly. Accounting for the uncertainty addresses possible variation in infestation rates and helps develop a more diversified survey strategy. The approach is generalizable and can support survey programmes for new pest incursions.},
  keywords = {Acceptance-sampling,ObsCite,Outbreak-detection},
  file = {/Volumes/External4TB/Documents/Repos/Notes/attachments/literature-notes/yemshanovAcceptanceSamplingCosteffective2020/@yemshanovAcceptanceSamplingCosteffective2020.pdf;/Users/arnoldc/Zotero/storage/Y3KX6MKP/5486411.html}
}

